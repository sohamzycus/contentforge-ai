# Speckit Jira Integration Configuration
# Copy this file to jira.env and fill in your credentials
# DO NOT commit jira.env to version control
#
# Setup Instructions:
# 1. Copy this file: cp jira.env.example jira.env
# 2. Generate an API token: https://id.atlassian.com/manage-profile/security/api-tokens
# 3. Fill in your email and API token below
# 4. Test the connection: ./.specify/scripts/bash/jira-fetch.sh test

# Jira Cloud API Configuration
JIRA_BASE_URL=https://pdtzycus.atlassian.net
JIRA_EMAIL=your.email@example.com
JIRA_API_TOKEN=YOUR_API_TOKEN_HERE

# Project Configuration (pre-filled for this repo)
JIRA_PROJECT_KEYS=ZPDT
JIRA_USE_PROXY=true

# Optional: Default JQL filter for fetching issues
JIRA_DEFAULT_JQL="project = ZPDT AND status != Done ORDER BY updated DESC"
