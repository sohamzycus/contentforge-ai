# JWT Secret Key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me

# AI — LLM (text generation for content, order parsing, etc.)
# Sign up free at https://api.together.xyz/signup → Settings → API Keys
AI_API_KEY=your-together-api-key
AI_BASE_URL=https://api.together.xyz/v1
AI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

# AI — Image generation
IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# To use a different provider (OpenAI, Groq, etc.), just change the base URL and model:
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile
